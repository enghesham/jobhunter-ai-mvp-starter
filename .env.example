APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=job_hunter
DB_USERNAME=postgres
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
JOBHUNTER_AI_ENABLED=false
JOBHUNTER_AI_PROVIDER=openrouter
JOBHUNTER_AI_PROVIDER_CHAIN=openrouter
JOBHUNTER_AI_TIMEOUT=30
JOBHUNTER_AI_BASE_URL=
JOBHUNTER_AI_CACHE_ENABLED=true
JOBHUNTER_AI_QUALITY_DASHBOARD_ENABLED=true
JOBHUNTER_OPENAI_MODEL=gpt-4.1-mini
JOBHUNTER_OPENROUTER_MODEL=openrouter/auto
JOBHUNTER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
JOBHUNTER_GEMINI_MODEL=gemini-2.5-flash
JOBHUNTER_GROQ_MODEL=llama-3.3-70b-versatile
#GROQ_MODEL=llama-3.1-8b-instant
JOBHUNTER_GROQ_BASE_URL=https://api.groq.com/openai/v1
JOBHUNTER_ANALYSIS_PROMPT_VERSION=v1
JOBHUNTER_MATCH_PROMPT_VERSION=v1
JOBHUNTER_RESUME_PROMPT_VERSION=v1
JOBHUNTER_APPLICATION_MATERIALS_PROMPT_VERSION=v1
JOBHUNTER_APPLY_PACKAGE_PROMPT_VERSION=v1
JOBHUNTER_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
JOBHUNTER_LOCAL_LLM_MODEL=llama3.1
JOBHUNTER_LOCAL_LLM_API_KEY=
JOBHUNTER_PYTHON_AI_SERVICE_URL=
JOBHUNTER_PYTHON_AI_SERVICE_KEY=
JOBHUNTER_BEDROCK_MODEL=anthropic.claude-3-5-sonnet
JOBHUNTER_MATCH_THRESHOLD=75
JOBHUNTER_OPPORTUNITY_MAX_JOBS_PER_REFRESH=200
JOBHUNTER_OPPORTUNITY_MIN_RELEVANCE_SCORE=45
JOBHUNTER_OPPORTUNITY_STORE_BELOW_THRESHOLD=false
JOBHUNTER_OPPORTUNITY_AUTO_AI_EVALUATION_ENABLED=false
JOBHUNTER_OPPORTUNITY_MAX_AI_EVALUATIONS_PER_REFRESH=0
JOBHUNTER_SCAN_HOURS=6
JOBHUNTER_ALLOWED_SOURCES=custom,rss,greenhouse,lever
JOBHUNTER_COLLECTION_SAFE_SOURCE_TYPES=rss,greenhouse,lever
JOBHUNTER_COLLECTION_FETCH_TIMEOUT=20
JOBHUNTER_COLLECTION_STORE_BELOW_THRESHOLD=false
JOBHUNTER_COLLECTION_SCHEDULE_EVERY_MINUTES=15
JOBHUNTER_PDF_DRIVER=html
JOBHUNTER_PDF_BROWSER_PATH=
JOBHUNTER_PDF_TIMEOUT=60
JOBHUNTER_MPDF_TEMP_DIR=

VITE_APP_NAME="${APP_NAME}"
